{
  "name": "music-production-roulette",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "css:watch": "postcss public/css/input.css -o public/css/output.css --watch",
    "css:build": "NODE_ENV=production postcss public/css/input.css -o public/css/output.css",
    "cljs:watch": "shadow-cljs watch app",
    "cljs:release": "shadow-cljs release app",
    "dev": "npm-run-all --parallel cljs:watch css:watch",
    "release": "npm-run-all cljs:release css:build"
  },
  "devDependencies": {
    "shadow-cljs": "^2.28.18",
    "postcss": "^8.5.0",
    "postcss-cli": "^11.0.0",
    "@tailwindcss/postcss": "^4.0.0",
    "tailwindcss": "^4.0.0",
    "npm-run-all": "^4.1.5"
  },
  "dependencies": {
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
